# ==================================================
# OS / editor
# ==================================================
.DS_Store
Thumbs.db
desktop.ini
.vscode/
.idea/

# ==================================================
# Jupyter / Python cache
# ==================================================
.ipynb_checkpoints/
*.log
*.nbconvert.ipynb
__pycache__/
*.pyc

# ==================================================
# Local virtual environments (do NOT version)
# ==================================================
.venv/
venv/
env/
Scripts/
Lib/
Include/
share/
pyvenv.cfg
conda-meta/

# ==================================================
# Temporary / backup files
# ==================================================
*.tmp
*.bak

# ==================================================
# Scientific input data (NOT versioned)
# ==================================================
data/raw/**
data/processed/**

# Large scientific source formats outside canonical release
*.xlsx
*.xls
*.nc
*.grd
*.tif
*.tiff
*.qix
*.aux.xml

# Shapefile components outside canonical release
*.shp
*.shx
*.dbf
*.prj
*.cpg

# Tabular / geospatial heavy intermediates outside canonical release
*.parquet
*.gpkg

# ==================================================
# Re-include canonical reproducible outputs
# ==================================================
!public_release/**
!public_release/**/*.csv
!public_release/**/*.json
!public_release/**/*.md
!public_release/**/*.txt
!public_release/**/*.png
!public_release/**/*.pdf
!public_release/**/*.gpkg

!public_release_package/**
!public_release_package/**/*.tsv
!public_release_package/**/*.png
!public_release_package/**/*.pdf

# ==================================================
# Optional: ignore legacy folders if they still exist
# ==================================================
public/**